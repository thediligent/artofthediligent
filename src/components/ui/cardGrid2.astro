---
import type { ImageMetadata } from 'astro';

interface Props {
  categories: {
    title: string;
    url: string;
    image: string | ImageMetadata;
    alt?: string;
  }[];
  colsSm?: number;
  colsMd?: number;
  colsLg?: number;
}

let { categories, colsSm = 2, colsMd = 3, colsLg = 4 } = Astro.props;
---

<div class="p-4 mx-auto">
  <div class={`grid grid-cols-${colsSm} md:grid-cols-${colsMd} lg:grid-cols-${colsLg} gap-6`}>
    {
      categories.map((category) => (
        <a href={category.url} class="block">
          <div class="relative group overflow-hidden rounded-lg">
            <img
              src={typeof category.image === 'string' ? category.image : category.image.src}
              alt={category.alt || category.title}
              class="w-full h-64 object-cover transition-transform duration-300 group-hover:scale-110"
            />
            <div class="absolute inset-0 bg-black bg-opacity-20 group-hover:bg-opacity-40 transition-opacity duration-300 flex items-end">
              <h3 class="text-white text-xl font-semibold p-6 w-full bg-gradient-to-t from-black/60 to-transparent">
                {category.title}
              </h3>
            </div>
          </div>
        </a>
      ))
    }
  </div>
</div>
