---
import type { ImageMetadata } from 'astro';

interface Props {
  products: {
    title: string;
    url: string;
    image: string | ImageMetadata;
    alt?: string;
    price: string;
  }[];
  colsSm?: number;
  colsMd?: number;
  colsLg?: number;
}

let { products, colsSm = 2, colsMd = 3, colsLg = 4 } = Astro.props;
---

<div class="p-4 mx-auto">
  <div class={`grid grid-cols-${colsSm} md:grid-cols-${colsMd} lg:grid-cols-${colsLg} gap-6`}>
    {
      products.map((product) => (
        <a href={product.url} class="block">
          <div class="relative group overflow-hidden rounded-lg">
            <img
              src={typeof product.image === 'string' ? product.image : product.image.src}
              alt={product.alt || product.title}
              class="w-full h-128 object-cover transition-transform duration-300 group-hover:scale-110"
            />
            <div class="absolute inset-0 bg-black bg-opacity-20 group-hover:bg-opacity-40 transition-opacity duration-300 flex items-end">
              <h3 class="hidden text-white text-xl font-semibold p-6 w-full bg-gradient-to-t from-black/60 to-transparent">
                {product.title}
              </h3>
            </div>
          </div>
          <h4 class="text-gray-900 dark:text-gray-200 text-lg font-medium mt-2">{product.title}</h4>
          <p class="text-sm text-gray-500">starting at</p>
          <p class="text-gray-900 dark:text-gray-200 text text-lg font-semibold">${product.price}</p>
        </a>
      ))
    }
  </div>
</div>
