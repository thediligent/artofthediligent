---
import { getFeaturedProducts } from '~/utils/products';
import { cleanSlug } from '~/utils/permalinks';
import SnipcartBuyButton from './SnipcartBuyButton.astro';

export interface Props {
  limit?: number;
  collection?: string;
  showAddToCart?: boolean;
  title?: string;
  subtitle?: string;
  columns?: 2 | 3 | 4;
}

const { 
  limit = 4, 
  collection, 
  showAddToCart = true,
  title = 'Featured Products',
  subtitle = 'Hand-picked items just for you',
  columns = 4
} = Astro.props;

// Get featured products
let products = await getFeaturedProducts();

// Filter by collection if specified
if (collection) {
  products = products.filter(p => p.data.collection === collection);
}

// Apply limit
products = products.slice(0, limit);

const getDisplayPrice = (product: typeof products[0]) => {
  return product.data.onSale && product.data.salePrice
    ? product.data.salePrice
    : product.data.price;
};

const gridCols = {
  2: 'sm:grid-cols-2',
  3: 'sm:grid-cols-2 lg:grid-cols-3',
  4: 'sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4'
};
---

<section class="py-12">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <!-- Header -->
    <div class="text-center mb-10">
      <h2 class="text-3xl font-bold tracking-tight text-gray-900 dark:text-white sm:text-4xl">
        {title}
      </h2>
      {subtitle && (
        <p class="mt-4 text-lg text-gray-600 dark:text-gray-400">
          {subtitle}
        </p>
      )}
    </div>

    <!-- Products Grid -->
    {products.length === 0 ? (
      <div class="text-center py-12">
        <p class="text-gray-600 dark:text-gray-400">No featured products available at the moment.</p>
      </div>
    ) : (
      <div class={`grid grid-cols-1 ${gridCols[columns]} gap-x-6 gap-y-10`}>
        {products.map((product) => {
          const productSlug = cleanSlug(product.data.title);
          const displayPrice = getDisplayPrice(product);
          
          return (
            <div class="group relative">
              <a href={`/products/${productSlug}`}>
                <div class="relative aspect-square w-full overflow-hidden rounded-lg bg-gray-100 dark:bg-gray-800">
                  <img
                    src={product.data.image}
                    alt={product.data.title}
                    class="h-full w-full object-cover object-center group-hover:opacity-75 transition-opacity duration-300"
                  />
                  
                  {/* Sale Badge */}
                  {product.data.onSale && product.data.salePercent && (
                    <div class="absolute top-3 right-3 bg-red-500 text-white text-xs font-bold px-3 py-1 rounded-full shadow-lg">
                      SAVE {product.data.salePercent}%
                    </div>
                  )}
                  
                  {/* Featured Star */}
                  <div class="absolute top-3 left-3 bg-indigo-600 text-white p-2 rounded-full shadow-lg">
                    <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20">
                      <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
                    </svg>
                  </div>
                </div>

                <div class="mt-4">
                  <h3 class="text-lg font-medium text-gray-900 dark:text-gray-200 group-hover:text-indigo-600 dark:group-hover:text-indigo-400 transition-colors">
                    {product.data.title}
                  </h3>
                  
                  <p class="mt-1 text-sm text-gray-500 dark:text-gray-400">
                    {product.data.collection}
                  </p>
                  
                  <div class="mt-2 flex items-center gap-2">
                    {product.data.onSale && product.data.salePrice ? (
                      <>
                        <p class="text-lg font-bold text-red-600 dark:text-red-400">
                          ${product.data.salePrice}
                        </p>
                        <p class="text-sm text-gray-500 dark:text-gray-400 line-through">
                          ${product.data.price}
                        </p>
                      </>
                    ) : (
                      <p class="text-lg font-bold text-gray-900 dark:text-gray-200">
                        ${product.data.price}
                      </p>
                    )}
                  </div>

                  {/* Rating */}
                  {product.data.rating && (
                    <div class="mt-2 flex items-center">
                      <div class="flex">
                        {[...Array(5)].map((_, i) => (
                          <svg
                            class={`h-4 w-4 ${i < Math.floor(product.data.rating || 0) ? 'text-yellow-400' : 'text-gray-200 dark:text-gray-600'}`}
                            fill="currentColor"
                            viewBox="0 0 20 20"
                          >
                            <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
                          </svg>
                        ))}
                      </div>
                      {product.data.reviewCount && (
                        <span class="ml-2 text-xs text-gray-500 dark:text-gray-400">
                          ({product.data.reviewCount})
                        </span>
                      )}
                    </div>
                  )}
                </div>
              </a>

              {/* Add to Cart Button */}
              {showAddToCart && (
                <div class="mt-4">
                  <SnipcartBuyButton
                    id={product.data.id}
                    name={product.data.title}
                    price={displayPrice}
                    url={`/products/${productSlug}`}
                    description={product.data.description}
                    image={product.data.image}
                    categories={product.data.collection}
                    variant="secondary"
                  >
                    Add to Cart
                  </SnipcartBuyButton>
                </div>
              )}
            </div>
          );
        })}
      </div>
    )}

    <!-- View All Link -->
    {products.length > 0 && (
      <div class="mt-12 text-center">
        <a
          href="/shop"
          class="inline-flex items-center justify-center rounded-md border border-transparent bg-indigo-600 px-8 py-3 text-base font-medium text-white hover:bg-indigo-700 transition-colors"
        >
          View All Products
          <svg class="ml-2 h-5 w-5" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
          </svg>
        </a>
      </div>
    )}
  </div>
</section>
