        <!-- Description -->
        <p id="qv-description" class="mt-4 text-sm text-gray-600"></p>

        <!-- Form -->
        <form id="qv-form" class="mt-6">
          
          <!-- Color options (if available) -->
          <fieldset id="qv-colors-section" class="hidden mt-6">
            <legend class="block text-sm font-medium text-gray-900">Color</legend>
            <div id="qv-colors" class="mt-3 flex gap-4">
              <!-- Colors will be populated dynamically -->
            </div>
          </fieldset>

          <!-- Size options (if available) -->
          <fieldset id="qv-sizes-section" class="hidden mt-8">
            <div class="flex items-center justify-between">
              <legend class="block text-sm font-medium text-gray-900">Size</legend>
              <a href="#" class="text-sm font-medium text-indigo-600 hover:text-indigo-500">Size guide</a>
            </div>
            <div id="qv-sizes" class="mt-3 grid grid-cols-3 gap-3 sm:grid-cols-4">
              <!-- Sizes will be populated dynamically -->
            </div>
          </fieldset>

          <button 
            type="button" 
            id="qv-add-to-cart"
            class="snipcart-add-item mt-8 w-full rounded-md bg-indigo-600 px-6 py-3 text-base font-medium text-white hover:bg-indigo-700 focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:ring-offset-2"
          >
            Add to bag
          </button>

          <p class="mt-4 text-center text-sm">
            <a id="qv-view-details" href="#" class="font-medium text-indigo-600 hover:text-indigo-500">View full details</a>
          </p>
        </form>
      </div>
    </div>
  </div>
</div>

<script>
  interface ProductQuickViewData {
    id: string;
    title: string;
    price: string | number;
    salePrice?: string | number;
    onSale?: boolean;
    image: string;
    description?: string;
    url: string;
    categories?: string;
    colors?: Array<{ name: string; class: string }>;
    sizes?: string[];
  }

  function initQuickView() {
    const modal = document.getElementById('quick-view-modal');
    const closeBtn = document.getElementById('close-quick-view');

    // Close modal function
    function closeModal() {
      modal?.classList.remove('active');
      document.body.style.overflow = '';
    }

    // Close button handler
    closeBtn?.addEventListener('click', closeModal);

    // Close on backdrop click
    modal?.addEventListener('click', (e) => {
      if (e.target === modal) {
        closeModal();
      }
    });

    // Close on Escape key
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && modal?.classList.contains('active')) {
        closeModal();
      }
    });

    // Open quick view function
    // eslint-disable-next-line @typescript-eslint/no-explicit-any
    (window as any).openQuickView = function(productData: ProductQuickViewData) {
      // Populate modal with product data
      const img = document.getElementById('qv-image') as HTMLImageElement;
      const title = document.getElementById('qv-title');
      const price = document.getElementById('qv-price');
      const description = document.getElementById('qv-description');
      const viewDetailsLink = document.getElementById('qv-view-details') as HTMLAnchorElement;
      const addToCartBtn = document.getElementById('qv-add-to-cart') as HTMLButtonElement;

      if (img) img.src = productData.image;
      if (img) img.alt = productData.title;
      if (title) title.textContent = productData.title;
      if (description) description.textContent = productData.description || '';
      if (viewDetailsLink) viewDetailsLink.href = productData.url;

      // Handle price display
      if (price) {
        if (productData.onSale && productData.salePrice) {
          price.innerHTML = `
            <span class="text-xl font-bold text-red-600">$${productData.salePrice}</span>
            <span class="ml-2 text-sm text-gray-500 line-through">$${productData.price}</span>
          `;
        } else {
          price.textContent = `$${productData.price}`;
        }
      }

      // Handle colors
      const colorsSection = document.getElementById('qv-colors-section');
      const colorsContainer = document.getElementById('qv-colors');
      if (productData.colors && productData.colors.length > 0 && colorsContainer) {
        colorsSection?.classList.remove('hidden');
        colorsContainer.innerHTML = productData.colors.map((color, index: number) => `
          <label class="cursor-pointer">
            <input type="radio" name="color" value="${color.name.toLowerCase()}" class="sr-only" ${index === 0 ? 'checked' : ''} />
            <span class="block h-8 w-8 rounded-full border-2 ${color.class} ${index === 0 ? 'ring-2 ring-offset-2 ring-black' : 'border-gray-300'}"></span>
          </label>
        `).join('');
      } else {
        colorsSection?.classList.add('hidden');
      }

      // Handle sizes
      const sizesSection = document.getElementById('qv-sizes-section');
      const sizesContainer = document.getElementById('qv-sizes');
      if (productData.sizes && productData.sizes.length > 0 && sizesContainer) {
        sizesSection?.classList.remove('hidden');
        sizesContainer.innerHTML = productData.sizes.map((size: string) => {
          const isDisabled = size === 'XL';
          const isSelected = size === 'S';
          return `
            <label class="flex cursor-${isDisabled ? 'not-allowed' : 'pointer'} items-center justify-center rounded-md border ${
              isDisabled 
                ? 'border-gray-200 bg-gray-50 text-gray-400' 
                : isSelected 
                  ? 'border-indigo-600 bg-indigo-50 text-indigo-900' 
                  : 'border-gray-300 bg-white text-gray-900 hover:bg-gray-50'
            } px-3 py-2 text-sm font-medium shadow-sm focus:outline-none focus:ring-2 focus:ring-indigo-500">
              <input type="radio" name="size" value="${size.toLowerCase()}" ${isDisabled ? 'disabled' : ''} ${isSelected ? 'checked' : ''} class="sr-only" />
              <span>${size}</span>
            </label>
          `;
        }).join('');
      } else {
        sizesSection?.classList.add('hidden');
      }

      // Set up Snipcart button attributes
      if (addToCartBtn) {
        addToCartBtn.setAttribute('data-item-id', productData.id);
        addToCartBtn.setAttribute('data-item-name', productData.title);
        addToCartBtn.setAttribute('data-item-price', productData.price.toString());
        addToCartBtn.setAttribute('data-item-url', productData.url);
        addToCartBtn.setAttribute('data-item-description', productData.description || '');
        addToCartBtn.setAttribute('data-item-image', productData.image);
        if (productData.categories) {
          addToCartBtn.setAttribute('data-item-categories', productData.categories);
        }
      }

      // Show modal
      modal?.classList.add('active');
      document.body.style.overflow = 'hidden';
    };
  }

  // Initialize on page load
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initQuickView);
  } else {
    initQuickView();
  }

  // Re-initialize after page navigation (for SPA-like behavior)
  document.addEventListener('astro:page-load', initQuickView);
</script>
