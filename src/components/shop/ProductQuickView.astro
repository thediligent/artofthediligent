---
// This component is included via client-side script
// The modal content is populated dynamically via JavaScript
---

<style>
  .quick-view-modal {
    display: none;
  }
  
  .quick-view-modal.active {
    display: flex;
  }

  .quick-view-backdrop {
    animation: fadeIn 0.2s ease-out;
  }

  @keyframes fadeIn {
    from {
      opacity: 0;
    }
    to {
      opacity: 1;
    }
  }

  .quick-view-panel {
    animation: slideUp 0.3s ease-out;
  }

  @keyframes slideUp {
    from {
      opacity: 0;
      transform: translateY(20px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
</style>

<!-- Modal Container (Hidden by default) -->
<div id="quick-view-modal" class="quick-view-modal fixed inset-0 z-50 items-center justify-center bg-black/60 px-4 py-8">
  
  <!-- Modal panel -->
  <div class="quick-view-panel relative w-full max-w-3xl rounded-2xl bg-white shadow-2xl overflow-hidden">
    
    <!-- Close button -->
    <button type="button" id="close-quick-view" class="absolute right-4 top-4 z-10 rounded-full p-2 text-gray-500 hover:bg-gray-100 hover:text-gray-700 focus:outline-none focus:ring-2 focus:ring-indigo-500">
      <span class="sr-only">Close</span>
      <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
      </svg>
    </button>

    <div class="flex flex-col md:flex-row">
      
      <!-- Product image -->
      <div class="md:w-1/2 bg-gray-100">
        <img
          id="qv-image"
          src=""
          alt=""
          class="h-full w-full object-cover object-center"
        />
      </div>

      <!-- Product info & form -->
      <div class="flex-1 p-6 md:p-8">
        <h2 id="qv-title" class="text-2xl font-bold tracking-tight text-gray-900"></h2>
        <p id="qv-price" class="mt-2 text-xl font-medium text-gray-900"></p>

