---
import Layout from '~/layouts/PageLayout.astro';
import { getCollection } from 'astro:content';
import { cleanSlug } from '~/utils/permalinks';
import SnipcartBuyButton from '~/components/shop/SnipcartBuyButton.astro';

export async function getStaticPaths() {
  const products = await getCollection('products');
  return products.map((product) => ({
    params: { slug: cleanSlug(product.data.title) || product.id },
    props: { product },
  }));
}

const { product } = Astro.props;

// Use product images if available
const productImages = product.data.images || [product.data.image];

// Generate breadcrumb from collection
const breadcrumbs = [
  { label: product.data.collection, href: '#' },
  { label: product.data.tags[0] || 'Products', href: '#' },
  { label: product.data.title, current: true },
];

// Generate star ratings
const fullStars = Math.floor(product.data.rating || 0);
const emptyStars = 5 - Math.ceil(product.data.rating || 0);
---

<Layout title={`${product.data.title} | Art Of The Diligent`}>
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 py-8">
    
    <!-- Breadcrumb -->
    <nav aria-label="Breadcrumb" class="mb-8">
      <ol role="list" class="flex items-center space-x-2">
        {breadcrumbs.map((crumb, index) => (
          <>
            {index > 0 && <li class="text-gray-400 dark:text-gray-500">/</li>}
            <li>
              {crumb.current ? (
                <span class="text-sm font-medium text-gray-900 dark:text-gray-100" aria-current="page">{crumb.label}</span>
              ) : (
                <a href={crumb.href} class="text-sm font-medium text-gray-600 dark:text-gray-400 hover:text-gray-900 dark:hover:text-gray-100">{crumb.label}</a>
              )}
            </li>
          </>
        ))}
      </ol>
    </nav>

    <div class="lg:grid lg:grid-cols-2 lg:gap-x-8">
      
      <!-- Image column: Left on desktop, top on mobile -->
      <div class="lg:order-1">
        
        <!-- Mobile title, price, reviews -->
        <div class="mt-4 lg:hidden">
          <div class="flex items-center justify-between">
            <h1 class="text-3xl font-bold tracking-tight text-gray-900 dark:text-gray-100">{product.data.title}</h1>
            {product.data.onSale && (
              <span class="bg-red-500 text-white text-xs font-bold px-3 py-1 rounded-full">
                SALE {product.data.salePercent}% OFF
              </span>
            )}
          </div>
          
          {product.data.onSale && product.data.salePrice ? (
            <div class="mt-2 flex items-center gap-2">
              <p class="text-2xl font-medium text-red-600">${product.data.salePrice}</p>
              <p class="text-lg text-gray-500 dark:text-gray-400 line-through">${product.data.price}</p>
            </div>
          ) : (
            <p class="mt-2 text-2xl font-medium text-gray-900 dark:text-gray-100">${product.data.price}</p>
          )}

          <!-- Reviews -->
          {product.data.rating && product.data.reviewCount && (
            <div class="mt-4 flex items-center">
              <div class="flex items-center">
                {[...Array(fullStars)].map(() => (
                  <svg class="h-5 w-5 text-yellow-400" fill="currentColor" viewBox="0 0 20 20">
                    <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
                  </svg>
                ))}
                {[...Array(emptyStars)].map(() => (
                  <svg class="h-5 w-5 text-gray-200 dark:text-gray-700" fill="currentColor" viewBox="0 0 20 20">
                    <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
                  </svg>
                ))}
              </div>
              <p class="ml-3 text-sm font-medium text-gray-900 dark:text-gray-100">{product.data.rating} out of 5</p>
              <span class="mx-2 text-gray-400 dark:text-gray-500">·</span>
              <a href="#reviews" class="text-sm font-medium text-blue-600 dark:text-blue-400 hover:text-blue-500 dark:hover:text-blue-300">See all {product.data.reviewCount} reviews</a>
            </div>
          )}
        </div>

        <!-- Main image -->
        <div class="mt-6 lg:mt-0">
          <img
            src={productImages[0]}
            alt={product.data.title}
            class="h-auto w-full rounded-lg object-cover object-center lg:h-full"
          />
        </div>
      </div>

      <!-- Details column: Right on desktop, bottom on mobile -->
      <div class="mt-10 lg:mt-0 lg:order-2">
        
        <!-- Desktop title, price, reviews -->
        <div class="hidden lg:block">
          <div class="flex items-center justify-between">
            <h1 class="text-3xl font-bold tracking-tight text-gray-900 dark:text-gray-100">{product.data.title}</h1>
            {product.data.onSale && (
              <span class="bg-red-500 text-white text-xs font-bold px-3 py-1 rounded-full">
                SALE {product.data.salePercent}% OFF
              </span>
            )}
          </div>
          
          {product.data.onSale && product.data.salePrice ? (
            <div class="mt-4 flex items-center gap-3">
              <p class="text-3xl tracking-tight text-red-600 font-bold">${product.data.salePrice}</p>
              <p class="text-xl text-gray-500 dark:text-gray-400 line-through">${product.data.price}</p>
              <p class="text-sm text-green-600 font-semibold">
                Save ${(product.data.price - product.data.salePrice).toFixed(2)}!
              </p>
            </div>
          ) : (
            <p class="mt-4 text-3xl tracking-tight text-gray-900 dark:text-gray-100">${product.data.price}</p>
          )}

          <!-- Reviews -->
          {product.data.rating && product.data.reviewCount && (
            <div class="mt-6 flex items-center">
              <div class="flex items-center">
                {[...Array(fullStars)].map(() => (
                  <svg class="h-6 w-6 text-yellow-400" fill="currentColor" viewBox="0 0 20 20">
                    <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
                  </svg>
                ))}
                {[...Array(emptyStars)].map(() => (
                  <svg class="h-6 w-6 text-gray-200 dark:text-gray-700" fill="currentColor" viewBox="0 0 20 20">
                    <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
                  </svg>
                ))}
              </div>
              <p class="ml-3 text-sm font-medium text-gray-900 dark:text-gray-100">{product.data.rating} out of 5 stars</p>
              <span class="mx-2 text-gray-400 dark:text-gray-500">·</span>
              <a href="#reviews" class="text-sm font-medium text-blue-600 dark:text-blue-400 hover:text-blue-500 dark:hover:text-blue-300">See all {product.data.reviewCount} reviews</a>
            </div>
          )}
        </div>

        <!-- Form -->
        <form class="mt-8">
          
          <!-- Color -->
          {product.data.colors && product.data.colors.length > 0 && (
            <div>
              <h2 class="text-sm font-medium text-gray-900 dark:text-gray-100">Color</h2>
              <fieldset class="mt-3">
                <legend class="sr-only">Choose color</legend>
                <div class="flex gap-4">
                  {product.data.colors.map((color, index) => (
                    <label class="relative cursor-pointer">
                      <input 
                        type="radio" 
                        name="color" 
                        value={color.name.toLowerCase()} 
                        class="sr-only" 
                        checked={index === 0}
                      />
                      <span 
                        aria-hidden="true" 
                        class={`block h-8 w-8 rounded-full border border-gray-300 dark:border-gray-600 ${color.class} ${index === 0 ? 'ring-2 ring-gray-900 dark:ring-gray-100 ring-offset-2' : ''}`}
                      ></span>
                    </label>
                  ))}
                </div>
              </fieldset>
            </div>
          )}

          <!-- Size -->
          {product.data.sizes && product.data.sizes.length > 0 && (
            <div class="mt-8">
              <div class="flex items-center justify-between">
                <h2 class="text-sm font-medium text-gray-900 dark:text-gray-100">Size</h2>
                <a href="#" class="text-sm font-medium text-blue-600 dark:text-blue-400 hover:text-blue-500 dark:hover:text-blue-300">See sizing chart</a>
              </div>
              <fieldset class="mt-3">
                <legend class="sr-only">Choose size</legend>
                <div class="grid grid-cols-3 gap-4 sm:grid-cols-4">
                  {product.data.sizes.map((size, index) => {
                    const isDisabled = size === 'XL';
                    const isSelected = size === 'S';
                    return (
                      <label 
                        class={`group relative flex cursor-pointer items-center justify-center rounded-md border px-4 py-3 text-sm font-medium uppercase shadow-sm focus:outline-none ${
                          isDisabled 
                            ? 'cursor-not-allowed border-gray-200 dark:border-gray-700 bg-gray-50 dark:bg-gray-800 text-gray-400 dark:text-gray-500' 
                            : isSelected
                              ? 'border-gray-900 dark:border-gray-100 bg-gray-100 dark:bg-gray-700 text-gray-900 dark:text-gray-100'
                              : 'border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-800 text-gray-900 dark:text-gray-100 hover:bg-gray-50 dark:hover:bg-gray-700'
                        }`}
                      >
                        <input 
                          type="radio" 
                          name="size" 
                          value={size.toLowerCase()} 
                          disabled={isDisabled}
                          checked={isSelected}
                          class="sr-only" 
                        />
                        <span>{size}</span>
                      </label>
                    );
                  })}
                </div>
              </fieldset>
            </div>
          )}

          <div class="mt-8">
            <SnipcartBuyButton
              id={product.data.id}
              name={product.data.title}
              price={product.data.onSale && product.data.salePrice ? product.data.salePrice : product.data.price}
              url={Astro.url.pathname}
              description={product.data.description}
              image={product.data.image}
              categories={product.data.collection}
              variant="primary"
            >
              Add to cart
            </SnipcartBuyButton>
          </div>
        </form>

        <!-- Description -->
        <div class="mt-10">
          <h2 class="text-sm font-medium text-gray-900 dark:text-gray-100">Description</h2>
          <div class="mt-4 space-y-6 text-base text-gray-700 dark:text-gray-300">
            <p>{product.data.description}</p>
          </div>
        </div>

        <!-- Fabric & Care -->
        {product.data.fabricCare && product.data.fabricCare.length > 0 && (
          <div class="mt-10">
            <h2 class="text-sm font-medium text-gray-900 dark:text-gray-100">Fabric & Care</h2>
            <ul role="list" class="mt-4 list-disc space-y-2 pl-4 text-sm text-gray-600 dark:text-gray-400">
              {product.data.fabricCare.map((item) => (
                <li>{item}</li>
              ))}
            </ul>
          </div>
        )}

        <!-- Policies -->
        <div class="mt-10 border-t border-gray-200 dark:border-gray-700 pt-10">
          <dl class="space-y-6">
            <div class="flex">
              <dt class="flex items-center text-sm font-medium text-gray-900 dark:text-gray-100">
                <svg class="h-6 w-6 text-gray-600 dark:text-gray-400" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M8.25 18.75a1.5 1.5 0 01-3 0m3 0a1.5 1.5 0 00-3 0m3 0h6m-9 0H3.375a1.125 1.125 0 01-1.125-1.125V14.25m17.25 4.5a1.5 1.5 0 01-3 0m3 0a1.5 1.5 0 00-3 0m3 0h1.125c.621 0 1.129-.504 1.09-1.124a17.902 17.902 0 00-3.213-9.193 2.056 2.056 0 00-1.58-.86H14.25M16.5 18.75h-2.25m0-11.177v-.958c0-.568-.422-1.048-.987-1.106a48.554 48.554 0 00-10.026 0 1.106 1.106 0 00-.987 1.106v7.635m12-6.677v6.677m0 4.5v-4.5m0 0h-12" />
                </svg>
                <span class="ml-3">Free shipping</span>
              </dt>
              <dd class="ml-6 text-sm text-gray-600 dark:text-gray-400">On orders over $50</dd>
            </div>

            <div class="flex">
              <dt class="flex items-center text-sm font-medium text-gray-900 dark:text-gray-100">
                <svg class="h-6 w-6 text-gray-600 dark:text-gray-400" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M12 6v12m-3-2.818l.879.659c1.171.879 3.07.879 4.242 0 1.172-.879 1.172-2.303 0-3.182C13.536 12.219 12.768 12 12 12c-.725 0-1.45-.22-2.003-.659-1.106-.879-1.106-2.303 0-3.182s2.9-.879 4.006 0l.415.33M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
                </svg>
                <span class="ml-3">Secure payment</span>
              </dt>
              <dd class="ml-6 text-sm text-gray-600 dark:text-gray-400">Protected checkout</dd>
            </div>
          </dl>
        </div>

      </div>
    </div>
  </div>
</Layout>
