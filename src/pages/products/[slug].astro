---
import Layout from '~/layouts/PageLayout.astro';
import { getCollection } from 'astro:content';
import { cleanSlug } from '~/utils/permalinks';
import Content from '~/components/widgets/Content.astro';
import Button from '~/components/ui/Button.astro';
import artofthediligent from '~/assets/images/artofthediligent.webp';

export async function getStaticPaths() {
  const products = await getCollection('products');
  return products.map((product) => ({
    params: { slug: cleanSlug(product.data.title) || product.id },
    props: { product },
  }));
}

const { product } = Astro.props;

// Mock image array for the slider (replace with product.data.images if available)
const productImages = product.data.images || [
  artofthediligent.src,
  'https://swiperjs.com/demos/images/nature-2.jpg',
  'https://swiperjs.com/demos/images/nature-3.jpg',
  'https://swiperjs.com/demos/images/nature-4.jpg',
];
---

<Layout title={`${product.data.title} | Art Of The Diligent`}>
  <section class="py-8">
    <div class="flex flex-col lg:flex-row w-full">
      <div class="flex flex-col w-full lg:basis-[65vw] lg:flex-row-reverse">
        <div class="w-full basis-128 mb-8 lg:basis-[50vw] lg:mb-0 px-4 lg:pl-4">
          <!-- Main Image Slider -->
          <div
            style="--swiper-navigation-color: #fff; --swiper-pagination-color: #fff"
            class="swiper mySwiper2 min-h-[720px]"
          >
            <div class="swiper-wrapper">
              {
                productImages.map((img) => (
                  <div class="swiper-slide">
                    <img src={img} alt={product.data.title} class="w-full h-96 object-cover rounded" />
                  </div>
                ))
              }
            </div>
            <div class="swiper-button-next"></div>
            <div class="swiper-button-prev"></div>
          </div>
        </div>
        <div class="w-full lg:basis-[10vw] mt-4 lg:mt-0 px-4 lg:pr-4">
          <!-- Vertical/Horizontal Thumbnail Slider -->
          <div class="swiper mySwiper" style="height: 100%;">
            <div class="swiper-wrapper">
              {
                productImages.map((img) => (
                  <div class="swiper-slide">
                    <img src={img} alt={`${product.data.title} thumbnail`} class="w-full h-24 object-cover rounded" />
                  </div>
                ))
              }
            </div>
          </div>
        </div>
      </div>
      <div class="flex flex-col w-full basis-[35vw] lg:pl-8 mb-8 lg:mb-0 lg:mr-8">
        <div class="flex items-center justify-between">
          <h1 class="text-4xl font-bold mb-4">{product.data.title}</h1>
          <span class="bg-red-500 text-white text-xs px-2 py-1 rounded-full">NEW</span>
        </div>
        <p class="text-2xl text-gray-800 mb-4">${product.data.price}</p>
        <p class="text-2xl text-gray-600 mb-4">{product.data.size}</p>
        <p class="mb-4 text-gray-600">{product.data.description}</p>
        <p class="text-gray-600 mb-4">Tags: {product.data.tags.join(', ')}</p>
        <div class="flex items-center space-x-4">
          <button class="bg-black text-white px-6 py-2 rounded hover:bg-gray-800">ADD TO CART</button>
          <button class="border border-gray-300 px-6 py-2 rounded hover:bg-gray-100">ORDER BY OtherPay</button>
        </div>
      </div>
    </div>
  </section>

  <section class="py-16 bg-gray-100">
    <Content
      id="Web Design & Development Services"
      image={{
        src: 'https://s3.us-east-1.amazonaws.com/media.diligentmarketing.solutions/services/web-design/vehicle-floor-liner-web-design.webp',
        alt: 'Rubber vehicle floor liner Web Design',
        loading: 'eager',
        class: 'hidden lg:block rounded-lg shadow-lg',
      }}
    >
      <Fragment slot="content">
        <h2 class="text-center md:text-left text-2xl font-bold tracking-tight dark:text-white sm:text-3xl mb-8">
          Web Design & Development
        </h2>
        <h3 class="text-center md:text-left">Build Online Identity with Diligent Marketing Solutions</h3>
        <img
          src="https://s3.us-east-1.amazonaws.com/media.diligentmarketing.solutions/services/web-design/vehicle-floor-liner-web-design.webp"
          alt="Professional Web Design and Development Services by Diligent Marketing Solutions"
          class="w-full h-auto mb-6 rounded-lg shadow-lg py-3 lg:hidden"
        />
        <h3 class="text-1xl font-bold tracking-tight dark:text-white sm:text-2xl my-8">
          Why Most Websites Fail—and How We Fix It
        </h3>
        <p>
          Your website isn’t just a digital brochure—it’s your 24/7 storefront, lead generator, and growth engine. Yet
          most business owners settle for slow, outdated, or clunky sites that lose visitors the second they arrive.
        </p>
        <h4 class="py-4 font-bold text-xl">Invest in Professional Web Design and Development.</h4>
        <p>
          At Diligent Marketing Solutions, we build websites that don’t just look good—they perform. Fast, modern, and
          conversion-focused, our sites grab attention, guide visitors, and turn clicks into paying customers. From
          fixing weak user experience to boosting traffic and conversion rates, we tackle the issues that are quietly
          costing you revenue.
        </p>
        <p class="pt-4">
          Stop leaving money on the table. Let us create a website that reflects your brand, engages your audience, and
          drives real, measurable results.
        </p>
        <div class="mt-12 text-left">
          <Button
            href="/contact-us"
            text="Get A Free Website Customer Experience Audit"
            variant="primary"
            class="btn btn-primary px-6 py-3"
          />
        </div>
      </Fragment>
      <Fragment slot="bg">
        <div class="absolute inset-0 bg-zinc-50 dark:bg-transparent"></div>
      </Fragment>
    </Content>
  </section>
  

  <!-- Swiper CSS -->
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.css" />

  <!-- Custom Styles for Thumbnail Placement -->
  <style>
    .swiper.mySwiper {
      width: 100%;
      height: 100%;
      max-height: 400px;
    }
    .swiper.mySwiper .swiper-wrapper {
      flex-direction: row;
    }
    .swiper.mySwiper .swiper-slide {
      width: 25% !important;
      height: 100px;
      opacity: 0.4;
      margin-right: 10px;
    }
    .swiper.mySwiper .swiper-slide-thumb-active {
      opacity: 1;
    }
    .swiper.mySwiper2 {
      width: 100%;
      height: 400px;
    }
    .swiper.mySwiper2 .swiper-slide {
      background: #444;
      display: flex;
      justify-content: center;
      align-items: center;
    }
    .swiper.mySwiper2 .swiper-slide img {
      display: block;
      width: 100%;
      height: 100%;
      object-fit: cover;
    }
    .swiper-button-next,
    .swiper-button-prev {
      color: #fff;
    }
    @media (max-width: 1024px) {
      .swiper.mySwiper {
        max-height: none;
        height: auto;
      }
      .swiper.mySwiper .swiper-wrapper {
        flex-direction: row;
      }
      .swiper.mySwiper .swiper-slide {
        width: 25% !important;
        height: 100px;
        margin-right: 10px;
      }
      .swiper.mySwiper2 {
        height: 300px;
      }
    }
    @media (min-width: 1025px) {
      .swiper.mySwiper .swiper-wrapper {
        flex-direction: column;
      }
      .swiper.mySwiper .swiper-slide {
        width: 100% !important;
        height: 100px;
        margin-bottom: 10px;
        margin-right: 0;
      }
    }
  </style>

  <!-- Initialize Swiper -->
  <script client:only>
    import Swiper from 'https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.js';

    var swiper = new Swiper('.mySwiper', {
      direction: 'horizontal',
      loop: true,
      spaceBetween: 10,
      slidesPerView: 4,
      freeMode: true,
      watchSlidesProgress: true,
      breakpoints: {
        1025: {
          direction: 'vertical',
          slidesPerView: 4,
        },
      },
    });
    var swiper2 = new Swiper('.mySwiper2', {
      loop: true,
      spaceBetween: 10,
      navigation: {
        nextEl: '.swiper-button-next',
        prevEl: '.swiper-button-prev',
      },
      thumbs: {
        swiper: swiper,
      },
    });
  </script>
</Layout>
