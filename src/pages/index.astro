          title: 'Apparel',
          url: '/shop/apparel',
          image: 'https://art-evolves-content-drop.s3.us-east-1.amazonaws.com/products/apparel/apparel-category.webp',
          alt: 'Apparel collection',
        },
        {
          title: 'Posters',
          url: '/shop/posters',
