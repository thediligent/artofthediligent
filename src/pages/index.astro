---
import Layout from '~/layouts/PageLayout.astro';
import { getCollection } from 'astro:content';
import { cleanSlug, getPermalink } from '~/utils/permalinks';

import EditorsPicks from '~/components/widgets/EditorsPicks.astro';

import magazineCover from '~/assets/images/magazine-cover.webp';
import featuredSpot from '~/assets/images/art-evolves.webp';
import fashionEditorial from '~/assets/images/fashion-ai-articles.webp';
import cultureEditorial from '~/assets/images/culture-ai-articles.webp';
import fashionImage from '~/assets/images/fashion.webp';
import cultureImage from '~/assets/images/culture.webp';
import newsImage from '~/assets/images/news.webp';
import musicImage from '~/assets/images/music.webp';
import architectureImage from '~/assets/images/architecture.webp';
import artImage from '~/assets/images/art.webp';
import artistPrintsImage from '~/assets/images/artofthediligent-prints.webp';
import butterflyBgImage from '~/assets/images/butterflybg.webp';

import artofthediligent from '~/assets/images/artofthediligent.webp';
import derekImage from '~/assets/images/derek.webp';
import voltageImage from '~/assets/images/voltage.webp';
import jairoImage from '~/assets/images/jairo.webp';

import shopJournalsImage from '~/assets/images/journals.webp';
import shopBooksImage from '~/assets/images/books.webp';
import shopApparelImage from '~/assets/images/apparel.webp';
import shopPosterImage from '~/assets/images/posters.webp';
import shopAccessoriesImage from '~/assets/images/accessories.webp';
import shopMousepadsImage from '~/assets/images/mousepads.webp';

import CardGrid from '~/components/ui/cardGrid.astro';
import ProductGrid from '~/components/ui/productGrid.astro';
import CardGrid2 from '~/components/ui/cardGrid2.astro';
import ShopCollections from '~/components/ui/ShopCollections.astro';
import FeaturedProducts from '~/components/shop/FeaturedProducts.astro';
import HeroVideo from '~/components/widgets/Hero4-video.astro';
import Features2 from '~/components/widgets/Features2.astro';
import Steps from '~/components/widgets/Steps.astro';
import Content from '~/components/widgets/Content.astro';
import Content2 from '~/components/widgets/Content2.astro';
import BlogLatestPosts from '~/components/widgets/BlogLatestPosts.astro';
import FAQs from '~/components/widgets/FAQs.astro';
import Stats from '~/components/widgets/Stats.astro';

import Button from '~/components/ui/Button.astro';
import Image from '~/components/common/Image.astro';

const appStoreImg = '~/assets/images/app-store.png';
const appStoreDownloadLink = 'https://github.com/onwidget/astrowind';

const googlePlayImg = '~/assets/images/google-play.png';
const googlePlayDownloadLink = 'https://github.com/onwidget/astrowind';

const articles = await getCollection('articles');
const products = await getCollection('products');

const featuredMagazine = articles.find(
  (article) => article.data.category === 'Magazine Issues' && article.data.featured
);
const editorsPicks = articles.filter((article) => article.data.featured).slice(0, 3);
const featuredArtists = articles.filter((article) => article.data.category === 'Featured Artists').slice(0, 3);
const shopCollections = [...new Set(products.map((product) => product.data.collection))];
const mostRead = articles.sort((a, b) => {
  const dateA = a.data.date ? new Date(a.data.date).getTime() : 0;
  const dateB = b.data.date ? new Date(b.data.date).getTime() : 0;
  return dateB - dateA;
}).slice(0, 3);

const metadata = {
  title: 'Art Of The Diligent — Free template for creating websites with Astro + Tailwind CSS',
  ignoreTitleTemplate: true,
};
---

<Layout metadata={metadata}>
  <header class="py-0">
