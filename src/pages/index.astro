  </section>
  <!-- Artists Writings -->
  <section class="my-3 py-0 px-4 lg:px-6">
    <!-- CardGrid Widget **************
    <CardGrid2
      categories={[
        {
          title: 'Fashion',
          url: '/fashion',
          image: fashionImage,
