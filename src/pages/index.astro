      style='background-image: url("https://main.d3cz6hzvf33iri.amplifyapp.com/wp-content/uploads/2024/05/new-moon-goddess-mucha-art-of-the-diligent.jpg");'
    >
      <div class="flex items-center justify-center w-full h-full bg-gray-900 bg-opacity-50 py-28">
        <div class="text-center">
          <div class="container px-4 mx-auto">
            <div class="max-w-4xl mx-auto text-center">
              <span class="text-gray-200 font-semibold uppercase st">ART OF THE DILIGENT</span>
              <h2 class="mt-8 mb-6 text-5xl lg:text-7xl font-bold font-heading text-gray-100">
                Posters and Fine Art Prints
              </h2>
              <p class="max-w-3xl mx-auto mb-10 text-lg text-gray-300">
                Lorem ipsum dolor, sit amet consectetur adipisicing elit. Laborum sit cum iure qui, nostrum at sapiente
                ducimus.
              </p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </header>

  <!-- Shop Collections Widget ************** -->
  <div class="my-4">
    <div class="text-center pt-10 mb-0">
      <h2 class="font-black dark:text-white text-5xl lg:text-5xl mb-4 font-heading uppercase">Art Your Way</h2>
