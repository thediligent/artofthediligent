---
import type { InferGetStaticPropsType, GetStaticPaths } from 'astro';
import type { ImageMetadata } from 'astro';
import Layout from '~/layouts/MarkdownLayout.astro';
import { cleanSlug } from '~/utils/permalinks';
import { getCollection, getEntry } from 'astro:content';
import { findImage } from '~/utils/images';
import { blogPostRobots } from '~/utils/blog';

export const prerender = true;

export const getStaticPaths = (async () => {
  const articles = await getCollection('articles');
  return articles.map((article) => {
    if (!article.data.title) {
      console.error(`Article with id "${article.id}" is missing a title`);
      return null; // Skip articles without titles
    }
    const category = cleanSlug(article.data.category);
    const slug = cleanSlug(article.data.title);
    return {
      params: { 
        category: category,
        slug: slug || cleanSlug(article.id.replace(/\.md$/, '')), // Fallback to cleaned id
      },
      props: { article, articleId: article.id },
    };
  }).filter(Boolean); // Remove null entries
}) satisfies GetStaticPaths;

type Props = InferGetStaticPropsType<typeof getStaticPaths>;

const { article, articleId } = Astro.props as Props;

// Validate article existence
if (!article) {
  throw new Error(`Article not found for id: ${articleId}`);
}

const { Content } = await article.render();

// Validate title
if (!article.data.title) {
  throw new Error(`Article with id "${articleId}" is missing a title`);
}

const image = (await findImage(article.data.image)) as ImageMetadata | string | undefined;
const metadata = {
  title: article.data.title,
  robots: {
    index: blogPostRobots?.index ?? true,
    follow: blogPostRobots?.follow ?? true,
  },
  openGraph: {
    type: 'article',
    ...(image
      ? { images: [{ url: image, width: (image as ImageMetadata)?.width, height: (image as ImageMetadata)?.height }] }
      : {}),
  },
};
---

<Layout metadata={metadata}>
  <div class="grid grid-cols-1 md:grid-cols-4 gap-8">
    <div class="md:col-span-3">
      <img src={article.data.image} width="1920" height="1080" alt={article.data.title} class="w-full h-64 object-cover rounded mb-8" />
      <h1 class="text-4xl font-bold mb-4">{article.data.title}</h1>
      <p class="text-gray-600 mb-4">By {article.data.author} | {article.data.date.toDateString()}</p>
      <div class="prose max-w-none">
        <Content />
      </div>
    </div>
    <div class="md:col-span-1">
      <div class="bg-gray-200 p-4 rounded h-64 flex items-center justify-center">
        <p>AdSense/Ad Spot Placeholder</p>
      </div>
    </div>
  </div>
</Layout>