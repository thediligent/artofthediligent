---
import Banner from '~/components/shop/CategoryBanner.astro';
import Filters from '~/components/shop/CategoryMenuFilters.astro';
import ProductGrid from '~/components/shop/ProductGrid.astro';
import CategoryScroller from '~/components/shop/CategoryScroller.astro';
import Layout from '~/layouts/PageLayout.astro';

const metadata = {
  title: 'Shop',
};
---

<Layout metadata={metadata}>
  <div class="flex flex-col min-h-screen">
    <!-- Banner Section -->
    <div class="w-full">
      <Banner />
    </div>
    <!-- Main Content Section -->
    <div class="flex-1 flex flex-col md:flex-row max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-6 gap-6">
      <!-- Filters Sidebar -->
      <div class="w-full md:w-1/4 order-2 md:order-1">
        <Filters />
      </div>
      <!-- Category Scroller and Product Grid -->
      <div class="w-full md:w-3/4 order-1 md:order-2 flex flex-col gap-6">
        <div class="block md:hidden">
          <CategoryScroller />
        </div>
        <div class="flex-1">
          <ProductGrid />
        </div>
      </div>
    </div>
  </div>
</Layout>