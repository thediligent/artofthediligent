    <!-- Main Content Section -->
    <div class="flex-1 flex flex-col md:flex-row max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-6 gap-6">
      <!-- Filters Sidebar -->
      <div class="w-full md:w-1/4 order-2 md:order-1">
        <div class="sticky top-4">
          <Filters />
        </div>
      </div>
      
      <!-- Category Scroller and Product Grid -->
      <div class="w-full md:w-3/4 order-1 md:order-2 flex flex-col gap-6">
        <!-- Mobile Category Scroller -->
        <div class="block md:hidden">
          <CategoryScroller />
        </div>
        
        <!-- Page Header & Sorting -->
        <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4 pt-4 border-t border-gray-200 dark:border-gray-700">
          <div>
            <h1 class="text-2xl font-bold text-gray-900 dark:text-white">{pageTitle}</h1>
            <p class="text-sm text-gray-600 dark:text-gray-400 mt-1">
              {collection ? `Showing all ${collection.toLowerCase()} products` : 'Browse our complete collection'}
            </p>
          </div>
          
          <!-- Sort Dropdown -->
          <div class="flex items-center gap-2">
            <label for="sort" class="text-sm font-medium text-gray-700 dark:text-gray-300">Sort by:</label>
            <select
              id="sort"
              name="sort"
              class="rounded-md border-gray-300 dark:border-gray-600 dark:bg-gray-700 dark:text-white py-2 pl-3 pr-10 text-base focus:border-indigo-500 focus:outline-none focus:ring-indigo-500 sm:text-sm"
              onchange="window.location.href = window.location.pathname + '?' + new URLSearchParams({...Object.fromEntries(new URLSearchParams(window.location.search)), sort: this.value}).toString()"
            >
              <option value="featured" selected={sortParam === 'featured'}>Featured</option>
              <option value="price-asc" selected={sortParam === 'price-asc'}>Price: Low to High</option>
              <option value="price-desc" selected={sortParam === 'price-desc'}>Price: High to Low</option>
              <option value="rating" selected={sortParam === 'rating'}>Top Rated</option>
              <option value="title" selected={sortParam === 'title'}>Name: A-Z</option>
            </select>
          </div>
        </div>
        
        <!-- Products -->
        <div class="flex-1">
          <ProductGrid filter={filter} sort={sort} />
        </div>
      </div>
    </div>
  </div>
</Layout>