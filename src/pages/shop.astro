---
import Filters from '~/components/shop/CategoryMenuFilters.astro';
import ProductGrid from '~/components/shop/ProductGrid.astro';
import CategoryScroller from '~/components/shop/CategoryScroller.astro';
import Layout from '~/layouts/PageLayout.astro';
import type { ProductFilter, ProductSort } from '~/utils/products';

const metadata = {
  title: 'Shop',
};

// Get URL parameters for filtering
const url = Astro.url;
const collection = url.searchParams.get('collection') || undefined;
const color = url.searchParams.get('color') || undefined;
const size = url.searchParams.get('size') || undefined;
const onSale = url.searchParams.get('onSale') === 'true' || undefined;
const sortParam = url.searchParams.get('sort') || 'featured';

// Build filter object
const filter: ProductFilter = {
  collection,
  onSale,
};

// Add tag filter (color or size)
if (color || size) {
  // We'll filter by tags that match color or size
  // This is a simplified approach - you may want to enhance this
  filter.tag = color || size;
}

// Build sort object
let sort: ProductSort = { field: 'featured', order: 'desc' };
switch (sortParam) {
  case 'price-asc':
    sort = { field: 'price', order: 'asc' };
    break;
  case 'price-desc':
    sort = { field: 'price', order: 'desc' };
    break;
  case 'rating':
    sort = { field: 'rating', order: 'desc' };
    break;
  case 'title':
    sort = { field: 'title', order: 'asc' };
    break;
  default:
    sort = { field: 'featured', order: 'desc' };
}

// Build page title
let pageTitle = 'All Products';
if (collection) {
  pageTitle = collection;
} else if (onSale) {
  pageTitle = 'Sale Items';
}
---

<Layout metadata={metadata}>
  <div class="flex flex-col min-h-screen">
  <!-- Breadcrumb 
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-4">
      <nav class="flex" aria-label="Breadcrumb">
